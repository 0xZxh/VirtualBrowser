PORT=3001

# ── 存储模式 ─────────────────────────────────────────
# local  = 本机零依赖（SQLite 或 JSON，无需 Mongo）
# mongo  = 生产 / 正式环境（必须提供 MONGODB_URI）
STORAGE_DRIVER=local

# 本地模式（STORAGE_DRIVER=local）
LOCAL_STORAGE=sqlite
SQLITE_PATH=./data/local/app.db
# LOCAL_STORAGE=json 时使用：
# LOCAL_JSON_DIR=./data/local

# 生产模式（STORAGE_DRIVER=mongo）— 本地开发可留空
# MONGODB_URI=mongodb://vb_app:密码@127.0.0.1:27017/virtualbrowser?authSource=virtualbrowser

# Profile 快照 zip（两种模式共用）
DATA_DIR=./data

# ── IP Geo（本期公开；下期可开 IP_GEO_API_KEY）────────
# GEOIP_MMDB_PATH=./data/geoip/GeoLite2-City.mmdb
# MAXMIND_LICENSE_KEY=   # 仅下载脚本用（npm run geoip:update）
# MAXMIND_ACCOUNT_ID=    # 推荐：当前 MaxMind 下载 API 需要 Account ID + License Key
# IP_GEO_API_KEY=        # 预留，本期不读

# ── CORS（生产建议显式配置）──────────────────────────
# 未设或 * = 允许任意 Origin；多个用逗号分隔
# CORS_ORIGINS=https://admin.example.com
# CORS_ORIGINS=*

# ── Compat 自动化 API（同进程第二 listener）──────────
# 默认 9000；Header: api-key
# COMPAT_API_PORT=9000

# NODE_ENV=production
